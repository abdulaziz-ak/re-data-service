# Semicolon-separated transaction CSV paths (required in Compose)
BENCHMARKS_CSV_PATHS=/data/transactions-2026-02-23.csv;/data/Transactions.csv

# Residential sale index CSV (empty string skips index load)
INDEX_CSV_PATH=/data/Residential_Sale_Index.csv

# Area unit in DLD transaction CSVs: sqm | sqft
DLD_AREA_UNIT=sqm

# Price-per-sqft bounds (AED/sqft) for outlier filtering
PPSF_MIN=100
PPSF_MAX=20000

# Bind port (container listens on 8001 in Compose)
PORT=8001

# Echoed in GET /health
APP_ENV=local
